{
  "name": "@jeff-aporta/front-shared",
  "version": "0.1.1",
  "description": "CDN, worker-swagger y worker-unit-test compartidos (Jeff-Aporta).",
  "type": "module",
  "sideEffects": [
    "cdn/isa/js/**/*.js",
    "cdn/isa/js/index.js"
  ],
  "files": [
    "dist",
    "cdn",
    "cdn/_dist",
    "cloudflare-workers",
    "README.md"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./worker-swagger/swagger-toast": {
      "types": "./dist/worker-swagger/swagger-toast.d.ts",
      "default": "./dist/worker-swagger/swagger-toast.js"
    },
    "./worker-swagger/swagger-ui-shared": {
      "types": "./dist/worker-swagger/swagger-ui-shared.d.ts",
      "default": "./dist/worker-swagger/swagger-ui-shared.js"
    },
    "./worker-swagger/swagger-ui-html": {
      "types": "./dist/worker-swagger/swagger-ui-html.d.ts",
      "default": "./dist/worker-swagger/swagger-ui-html.js"
    },
    "./worker-swagger/swagger": {
      "types": "./dist/worker-swagger/swagger.d.ts",
      "default": "./dist/worker-swagger/swagger.js"
    },
    "./worker-swagger/auth-proxy": {
      "types": "./dist/worker-swagger/auth-proxy.d.ts",
      "default": "./dist/worker-swagger/auth-proxy.js"
    },
    "./worker-swagger/auth-guard": {
      "types": "./dist/worker-swagger/auth-guard.d.ts",
      "default": "./dist/worker-swagger/auth-guard.js"
    },
    "./worker-swagger/cors": {
      "types": "./dist/worker-swagger/cors.d.ts",
      "default": "./dist/worker-swagger/cors.js"
    },
    "./worker-swagger/openapi-params": {
      "types": "./dist/worker-swagger/openapi-params.d.ts",
      "default": "./dist/worker-swagger/openapi-params.js"
    },
    "./worker-unit-test/runner": {
      "types": "./dist/worker-unit-test/runner.d.ts",
      "default": "./dist/worker-unit-test/runner.js"
    },
    "./worker-unit-test/mount": {
      "types": "./dist/worker-unit-test/mount.d.ts",
      "default": "./dist/worker-unit-test/mount.js"
    },
    "./worker-unit-test/catalog-sync": {
      "types": "./dist/worker-unit-test/catalog-sync.d.ts",
      "default": "./dist/worker-unit-test/catalog-sync.js"
    },
    "./worker-unit-test/types": {
      "types": "./dist/worker-unit-test/types.d.ts",
      "default": "./dist/worker-unit-test/types.js"
    },
    "./cloudflare-workers/workers-runtime": "./cloudflare-workers/workers-runtime.d.ts"
  },
  "scripts": {
    "embed:templates": "node worker-swagger/embed-templates.mjs",
    "build": "npm run embed:templates && tsc -p tsconfig.build.json",
    "build:cdn-dist": "node scripts/build-cdn-dist.mjs",
    "build:neon-glass-demo": "node scripts/build-neon-glass-demo.mjs",
    "build:cdn": "npm run sync:core-shims && npm run build:cdn-dist && npm run build:neon-glass-demo",
    "sync:core-shims": "node scripts/write-core-shims.mjs",
    "prepublishOnly": "npm run build",
    "refresh:mui-llms": "curl -fsSL -o docs/mui-llms.txt https://mui.com/material-ui/llms.txt"
  },
  "peerDependencies": {
    "@hono/swagger-ui": "^0.5.1",
    "hono": "^4.6.0",
    "jose": "^5.9.0"
  },
  "peerDependenciesMeta": {
    "@hono/swagger-ui": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "jose": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hono/swagger-ui": "^0.5.1",
    "esbuild": "^0.25.12",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "typescript": "^5.8.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jeff-Aporta/front-shared.git"
  },
  "license": "UNLICENSED",
  "private": false
}
